# ──────────────────────────────────────────────────────────────────
#  NUSMods Sentiment — local environment template
#  Copy this file to ".env" and fill in your value.
#  NEVER commit the real ".env" to version control.
# ──────────────────────────────────────────────────────────────────

# Your Disqus PUBLIC key (not the Secret Key).
# Get it from: https://disqus.com/api/applications/ → your app → Settings
DISQUS_API_KEY=paste_your_public_key_here

# Optional: set the port (default 5000)
# PORT=5000
